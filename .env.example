BOT_TOKEN=123456:CHANGE_ME

# Local Bot API, e.g. http://127.0.0.1:8081
TELEGRAM_API_BASE_URL=http://127.0.0.1:8081
TELEGRAM_API_IS_LOCAL=true

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=playdl
DOWNLOAD_DIR=storage/downloads
MAX_PARALLEL_JOBS=2

# auto: prefer alltech gplay wrapper if present, then gplaydl, then apkeep.
# other values: alltech-gplay, gplaydl, apkeep, custom
PLAY_DOWNLOADER_BACKEND=auto
ALLTECH_GPLAY_PATH=tools/gplay
PLAY_ARCH=arm64
MERGE_SPLITS=true
APKEEP_SOURCE=
APKEEP_EMAIL=
APKEEP_TOKEN=

# Used only when PLAY_DOWNLOADER_BACKEND=custom.
# Template vars: {url} {package} {output_dir} {arch}
PLAY_DOWNLOADER_CMD=

APKEDITOR_JAR=tools/APKEditor.jar

# Optional override. Template vars: {input} {output}
APKS_TO_APK_CMD=

# Optional post-merge signing. Template vars: {input} {output}
# Example:
# SIGN_APK_CMD=apksigner sign --ks /root/.android/debug.keystore --ks-pass pass:android --key-pass pass:android --out "{output}" "{input}"
SIGN_APK_CMD=
